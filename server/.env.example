# =============================================
# Server Environment Variables Template
# =============================================
# Copy this file to .env and fill in the values

# Server
PORT=5004
NODE_ENV=development

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/ai-guidance-counselor
# Optional override; defaults to the database name in MONGODB_URI
# MONGODB_DATABASE=ai-guidance-counselor

# JWT Secrets (MUST change in production!)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS
CLIENT_URL=http://localhost:5173

# Default admin (auto-created on server start in development)
DEFAULT_ADMIN_EMAIL=admin@skillpatharchitect.ai
DEFAULT_ADMIN_PASSWORD=Admin123!
DEFAULT_ADMIN_NAME=System Admin

# Optional: also promote another email to admin
ADMIN_EMAIL=

EMAIL=ai.guidance.counselor@gmail.com
EMAIL_PASS=
