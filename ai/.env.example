# =============================================
# AI Service Environment Variables Template
# =============================================
# Copy this file to .env in the ai/ directory and fill in the values.
# Used by the LLM summary endpoint (POST /api/summary).

# Required: API key for your LLM provider
LLM_API_KEY=

# Optional: defaults to https://api.openai.com/v1
# Examples:
#   OpenAI:     https://api.openai.com/v1
#   Groq:       https://api.groq.com/openai/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# Optional: defaults to gpt-4o-mini
# Use whichever model your provider supports
LLM_MODEL=gpt-4o-mini
